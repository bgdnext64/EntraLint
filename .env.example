# EntraLint Environment Variables
# Copy this file to .env and fill in your values.

# Required: Your Entra ID app registration (public client) client ID.
# Register an app at https://entra.microsoft.com > App registrations > New registration
# - Set "Redirect URI" to http://localhost (Mobile and desktop applications)
# - Under "Authentication", enable "Allow public client flows"
# - Under "API permissions", add Microsoft Graph > Delegated > Policy.Read.All
ENTRALINT_CLIENT_ID=

# Optional: For client_credentials flow (CI/CD), set the client secret.
# ENTRALINT_CLIENT_SECRET=
